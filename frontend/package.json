{
  "name": "smart-college-admission-portal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api:win\" \"vite\"",
    "dev:api": "cd ../backend && sh -c 'if [ -x venv/bin/python ]; then exec venv/bin/python run.py; else exec python3 run.py; fi'",
    "dev:win": "concurrently -n api,web -c blue,green \"npm run dev:api:win\" \"vite\"",
    "dev:api:win": "cd ../backend && venv\\Scripts\\python run.py",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.1",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
}