# ── Backend environment template ──────────────────────────────────────────
# Copy this file to `.env` (in this backend/ folder) and adjust values.
# Every variable has a sensible default in config.py, so a first local run
# works even without a .env. Set the ones you actually need.

# --- Security / Auth ---
JWT_SECRET=change_me_to_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Server ---
# Local dev uses 5001 (macOS reserves 5000 for AirPlay). On Render, the
# platform injects PORT automatically, so this is ignored there.
PORT=5001

# --- Database ---
# The app tries MySQL first, then falls back to SQLite if FALLBACK_SQLITE=true.
FALLBACK_SQLITE=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tmec_admission

# Where SQLite + uploaded files are written. Defaults to this backend/ folder.
# On ephemeral hosts (e.g. Render) set DATA_DIR=/tmp.
# DATA_DIR=/tmp
UPLOAD_FOLDER=uploads

# --- AI Chatbot (admin Database Assistant) ---
# Without this, the admin chatbot runs in local template mode (no Gemini).
GEMINI_API_KEY=your_gemini_api_key_here

# --- Supabase (used for startup data sync and document URLs) ---
# These match the frontend Supabase project. The anon key is a public key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_BUCKET=documents
